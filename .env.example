# .env.example — LLM Serving Observability
# Copy to .env and adjust as needed: cp .env.example .env

# Ollama server URL
# Docker mode (default): http://ollama:11434
# Native Metal GPU mode: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Proxy listening port
PROXY_PORT=8000

# Maximum concurrent requests (semaphore limit)
MAX_CONCURRENT_REQUESTS=4

# Default model when not specified in request
DEFAULT_MODEL=qwen2.5:7b

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# (Optional) Override default ports for Prometheus/Grafana
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
