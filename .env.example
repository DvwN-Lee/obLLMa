# LLM Serving Observability — Environment Variables
# Copy this file: cp .env.example .env

# Ollama connection
# Docker Ollama (default): http://ollama:11434
# Native Ollama (Metal GPU): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Proxy settings
PROXY_PORT=8000
MAX_CONCURRENT_REQUESTS=4
DEFAULT_MODEL=qwen2.5:7b
LOG_LEVEL=info
