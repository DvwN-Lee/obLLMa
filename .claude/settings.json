{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list *)",
      "Bash(git tag *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(date)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(docker --version)",
      "Bash(docker compose version)",
      "Bash(ollama --version)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(mypy *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose build *)",
      "Bash(pip install *)",
      "Bash(pip freeze *)",
      "Bash(ollama list)",
      "Bash(ollama ps)",
      "Bash(curl http://localhost:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Read(./.env.example)",
      "Edit(./.env.example)",
      "Write(./.env.example)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(eval *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(~/.ssh/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/credentials*)",
      "Read(./**/secrets*)",
      "Read(./**/terraform.tfvars)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Edit(./.env.staging)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./**/credentials*)",
      "Edit(./**/secrets*)",
      "Edit(./**/terraform.tfvars)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./.env.staging)",
      "Write(./**/*.pem)",
      "Write(./**/*.key)",
      "Write(./**/credentials*)",
      "Write(./**/secrets*)",
      "Write(./**/terraform.tfvars)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(docker compose exec *)",
      "Bash(ollama pull *)",
      "Bash(ollama run *)",
      "Bash(pip uninstall *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/classify-bash.py"
          }
        ]
      }
    ],
    "PostToolUse": []
  }
}
